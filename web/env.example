# Site URL used for sitemap generation and canonical URLs
SITE_URL=https://your-production-domain.com

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your_supabase_anon_key

# Required for admin panel functionality (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key


# =============================================
# AI Provider Configuration
# =============================================
# Supported providers: google | anthropic | openai
# - google:     uses @google/genai SDK, requires GEMINI_API_KEY
# - anthropic:  uses @anthropic-ai/sdk SDK, requires ANTHROPIC_API_KEY
# - openai:     uses OpenAI-compatible API (e.g. SiliconFlow), requires AI_PROVIDER_BASE_URL + AI_PROVIDER_API_KEY
AI_PROVIDER=google

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI-compatible (e.g. SiliconFlow) — set AI_PROVIDER=openai to use
AI_PROVIDER_BASE_URL=https://api.siliconflow.cn/v1
AI_PROVIDER_API_KEY=your_openai_compatible_api_key

# =============================================
# AI Model Names
# =============================================
# All models must support multimodal (image + text) unless noted.
# Defaults shown below — override via environment variables.

# Model for problem extraction from images (multimodal required)
AI_MODEL_EXTRACTION=gemini-2.5-flash

# Model for error categorization
AI_MODEL_CATEGORISATION=gemini-2.5-flash

# Model for insight digest generation
AI_MODEL_DIGEST=gemini-3-flash-preview
